<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaSample.Maps.World.View"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:draw="using:LiveChartsCore.SkiaSharpView.SKCharts"
             xmlns:vms="using:ViewModelsSamples.Maps.World"
             x:DataType="vms:ViewModel">
    <UserControl.DataContext>
        <vms:ViewModel/>
    </UserControl.DataContext>
    <lvc:GeoMap
        x:Name="geoMap"
        Series="{Binding Series}"
        MapProjection="Mercator"
        LegendPosition="Right">
        <lvc:GeoMap.Title>
            <lvc:XamlDrawnLabelVisual
                Text="World population by country"
                TextSize="20"
                Padding="{lvc:Padding '12'}"/>
        </lvc:GeoMap.Title>
        <lvc:GeoMap.Legend>
            <draw:SKHeatLegend BadgePadding="{lvc:Padding '20, 16, 8, 16'}"/>
        </lvc:GeoMap.Legend>
    </lvc:GeoMap>
</UserControl>
